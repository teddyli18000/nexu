# Sandbox image for OpenClaw agent exec isolation.
# Pre-installs common skill dependencies to avoid repeated downloads.
FROM node:22-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g wrangler sharp

# NODE_PATH enables CJS require() and createRequire() to find globally
# installed packages. ESM scripts should use createRequire() for these deps.
ENV NODE_PATH=/usr/local/lib/node_modules
