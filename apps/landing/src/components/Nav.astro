---
// Nav.astro — Fixed navigation matching source nav.html
---

<header
  id="site-nav"
  class="fixed top-0 z-20 w-full transition-all duration-500"
  data-theme="light"
>
  <div id="nav-blur-wrap">
    <div class="container">
