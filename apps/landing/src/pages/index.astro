---
import "../styles/global.css";
import {
  ArrowRight,
  BarChart3,
  Blocks,
  Brain,
  Clock,
  Code2,
  MessageSquare,
  PenTool,
  Rocket,
  Search,
  Terminal,
  Workflow,
  Zap,
} from "lucide-react";
import DemoSection from "../components/DemoSection";
import FAQSection from "../components/FAQSection";
import LobsterCursorEffect from "../components/LobsterCursorEffect";
import BrandMark from "../components/BrandMark.astro";

const capabilities = [
  { Icon: Rocket, label: "1-minute launch" },
  { Icon: Brain, label: "Persistent memory" },
  { Icon: Workflow, label: "1,000+ built-in tools" },
  { Icon: MessageSquare, label: "Runs in team chat" },
  { Icon: Clock, label: "24/7 execution" },
];

const features = [
  {
    Icon: Code2,
    title: "Build & ship from chat",
    desc: '"Build me a flashcard game for learning English" and your lobster writes the code, deploys it, and returns a live link.',
  },
  {
    Icon: BarChart3,
    title: "Analyze data in minutes",
    desc: "Drop in a spreadsheet and your lobster finds trends, builds charts, and delivers recommendations with source notes.",
  },
  {
    Icon: PenTool,
    title: "Write content that ships",
    desc: "Turn changelogs and meeting notes into launch posts, customer updates, and investor emails without switching tools.",
  },
  {
    Icon: MessageSquare,
    title: "Lives where your team talks",
    desc: "No extra app to train. nexu runs directly in Slack, Discord, Telegram, and WhatsApp with one shared memory layer.",
  },
  {
    Icon: Workflow,
    title: "Automates recurring work",
    desc: 'Set routines like "every Friday summarize Slack and send a newsletter" once, then let your lobster run them automatically.',
  },
  {
    Icon: Brain,
    title: "Compounds team context",
    desc: "It remembers decisions, preferences, and project history so your team keeps momentum even when people rotate.",
  },
];

const steps = [
  {
    step: "01",
    title: "Create workspace",
    desc: "Start with email and name your workspace. You are ready in under a minute.",
    Icon: Rocket,
  },
  {
    step: "02",
    title: "Connect team chat",
    desc: "Add nexu to Slack, Discord, Telegram, or WhatsApp. Your lobster joins where work already happens.",
    Icon: Blocks,
  },
  {
    step: "03",
    title: "Run real work",
    desc: "Ask in plain language. nexu executes tasks, posts updates, and keeps memory for the next request.",
    Icon: Terminal,
  },
];

const useCases = [
  {
    Icon: Code2,
    tag: "App",
    prompt: '"Build my daughter a vocabulary flashcard game — cute style"',
    result:
      "Creates React game from scratch · 48 word cards · pronunciation · auto-deployed, share the link to play",
    time: "~45s",
  },
  {
    Icon: BarChart3,
    tag: "Data",
    prompt: '"Find the fastest-growing category in this sales data"',
    result:
      "Analyzes 12,000+ records · generates trend charts + category rankings + growth forecast dashboard",
    time: "~35s",
  },
  {
    Icon: PenTool,
    tag: "Content",
    prompt:
      '"Write a blog post + Twitter Thread from this week\'s product updates"',
    result: "1,200-word blog + 8-tweet thread + SEO summary, ready to publish",
    time: "~30s",
  },
  {
    Icon: Code2,
    tag: "Tool",
    prompt: '"Build a customer feedback form that exports to CSV"',
    result:
      "Full-stack form app · ratings + text + tag filters + one-click export · live in seconds",
    time: "~40s",
  },
  {
    Icon: Workflow,
    tag: "Automation",
    prompt:
      '"Every Friday, summarize our Slack discussions and send a newsletter"',
    result:
      "Scheduled workflow · auto-fetch → AI summary → format → send email, fully hands-free",
    time: "~20s",
  },
  {
    Icon: Search,
    tag: "Research",
    prompt:
      '"Research AI coding competitors and build a pricing comparison table"',
    result:
      "Covers 6 competitors · feature comparison + pricing matrix + differentiation recommendations",
    time: "~60s",
  },
];

const stats = [
  { num: "1 min", label: "To launch", sub: "Connect and go live" },
  {
    num: "24/7",
    label: "Execution window",
    sub: "Your lobster never sleeps",
  },
  {
    num: "1,000+",
    label: "Built-in tools",
    sub: "Code, data, content, automation",
  },
  { num: "0", label: "Ops overhead", sub: "Hosted by default" },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link id="app-favicon" rel="icon" type="image/svg+xml" href="/favicon/favicon-light.svg" />
    <script>
      (() => {
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const updateFavicon = () => {
          const link = document.getElementById("app-favicon");
          if (!link) return;
          link.setAttribute("href", media.matches ? "/favicon/favicon-dark.svg" : "/favicon/favicon-light.svg");
        };
        updateFavicon();
        if (typeof media.addEventListener === "function") {
          media.addEventListener("change", updateFavicon);
          return;
        }
        media.addListener(updateFavicon);
      })();
    </script>
    <title>Nexu - Your team chat AI workspace</title>
    <meta name="description" content="Turn team chat into execution. Launch in 1 minute, run 1,000+ built-in tools, and keep persistent memory in Slack, Discord, Telegram, and WhatsApp." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <LobsterCursorEffect client:load />
    <div class="min-h-full bg-surface-0 relative">

      {/* Nav */}
      <nav class="sticky top-0 z-50 border-b backdrop-blur-md border-border bg-surface-0/85">
        <div class="flex justify-between items-center px-4 sm:px-6 mx-auto max-w-5xl h-14">
          <div class="flex items-center gap-2.5">
            <BrandMark className="w-7 h-7" />
            <span class="text-sm font-semibold tracking-tight text-text-primary">Nexu</span>
          </div>
          <div class="hidden md:flex items-center gap-6 text-[13px] text-text-tertiary">
            <a href="#scenarios" class="transition-colors hover:text-text-primary">Scenarios</a>
            <a href="#features" class="transition-colors hover:text-text-primary">Features</a>
            <a href="#how" class="transition-colors hover:text-text-primary">How it works</a>
            <a href="#faq" class="transition-colors hover:text-text-primary">FAQ</a>
          </div>
          <div class="flex items-center">
            <a href="/auth" class="px-3 sm:px-4 py-1.5 bg-accent hover:bg-accent-hover text-accent-fg rounded-md text-[12px] sm:text-[13px] font-medium transition-colors inline-flex items-center gap-1.5">
              Get started free <ArrowRight size={14} />
            </a>
          </div>
        </div>
      </nav>

      {/* Hero */}
      <section class="overflow-hidden relative">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(var(--color-accent-rgb,99,102,241),0.06)_0%,transparent_50%)]"></div>
        <div class="absolute inset-0 opacity-15" style="background-image: linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px); background-size: 56px 56px;"></div>
        <div class="relative px-4 sm:px-6 pt-16 sm:pt-20 md:pt-24 pb-14 sm:pb-16 md:pb-20 mx-auto max-w-4xl text-center">
          <div class="inline-flex gap-2 items-center px-3 py-1 mb-8 text-xs font-medium rounded-full border border-accent/20 text-accent bg-accent/5">
            <Zap size={12} /> Live beta · no setup tax
          </div>
          <h1 class="text-[32px] sm:text-[40px] md:text-[42px] font-bold text-text-primary mb-5 sm:mb-6 leading-[1.15] tracking-tight">
            Your team chat just became your AI workspace<br />
            <span class="text-accent">1-minute launch. Persistent team memory.</span>
          </h1>
          <p class="mx-auto mb-7 sm:mb-8 max-w-2xl text-base sm:text-lg leading-relaxed text-text-tertiary">
            nexu puts OpenClaw into the place your team already works: Slack, Discord, Telegram, and WhatsApp.<br class="hidden sm:block" />
            No YAML, no context resets, no tool sprawl. Ask in chat and your lobster gets it done.
          </p>
          <div class="flex flex-wrap gap-2 justify-center mb-10">
            {capabilities.map((cap) => (
              <span class="inline-flex gap-1.5 items-center px-3 py-1.5 rounded-full text-[13px] font-medium border transition-colors bg-surface-1 text-text-secondary border-border hover:border-border-hover">
                <cap.Icon size={14} />
                {cap.label}
              </span>
            ))}
          </div>
          <div class="flex gap-3 justify-center items-center mx-auto mb-6 max-w-md">
            <a href="/auth" class="flex gap-2 items-center px-6 sm:px-8 py-3 text-sm font-semibold rounded-lg transition-all bg-accent hover:bg-accent-hover text-accent-fg hover:shadow-lg hover:shadow-accent/20">
              Get started free <ArrowRight size={14} />
            </a>
          </div>
          <div class="flex items-center justify-center text-[13px] text-text-muted">
            <span>Built for teams that move fast and hate workflow fragmentation.</span>
          </div>
        </div>
      </section>

      {/* Demo (React island — interactive tabs) */}
      <DemoSection client:visible />

      {/* Features */}
      <section id="features" class="px-4 sm:px-6 py-16 sm:py-20 md:py-24 mx-auto max-w-4xl">
        <div class="mb-14 text-center">
          <div class="text-[11px] font-semibold text-accent mb-3 tracking-widest uppercase">Capabilities</div>
          <h2 class="text-2xl font-bold tracking-tight text-text-primary">OpenClaw power without OpenClaw friction.</h2>
          <p class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-text-tertiary">From task execution to reporting, nexu runs beside your team in chat with memory and production-ready defaults.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-5 lg:mb-10">
          {features.slice(0, 3).map((f) => (
            <div class="p-6 rounded-xl border transition-colors bg-surface-1 border-border hover:border-border-hover group">
              <div class="flex justify-center items-center w-10 h-10 rounded-xl bg-accent/10 mb-4">
                <f.Icon size={20} className="text-accent" />
              </div>
              <div class="text-[14px] font-semibold text-text-primary mb-2">{f.title}</div>
              <div class="text-[13px] text-text-muted leading-relaxed">{f.desc}</div>
            </div>
          ))}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {features.slice(3).map((f) => (
            <div class="p-6 rounded-xl border transition-colors bg-surface-1 border-border hover:border-border-hover group">
              <div class="flex justify-center items-center w-10 h-10 rounded-xl bg-accent/10 mb-4">
                <f.Icon size={20} className="text-accent" />
              </div>
              <div class="text-[14px] font-semibold text-text-primary mb-2">{f.title}</div>
              <div class="text-[13px] text-text-muted leading-relaxed">{f.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <div class="px-4 sm:px-6 mx-auto max-w-4xl"><div class="border-t border-border"></div></div>

      {/* How it works */}
      <section id="how" class="px-4 sm:px-6 py-16 sm:py-20 md:py-24 mx-auto max-w-4xl">
        <div class="mb-14 text-center">
          <div class="text-[11px] font-semibold text-accent mb-3 tracking-widest uppercase">How it works</div>
          <h2 class="text-2xl font-bold tracking-tight text-text-primary">Go from zero to daily value in 3 steps.</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
          {steps.map((s, i) => (
            <div class="relative text-center">
              {i < 2 && <div class="hidden md:block absolute -right-5 top-7 w-10 border-t border-dashed border-border"></div>}
              <div class="flex justify-center items-center mx-auto mb-5 w-14 h-14 rounded-2xl bg-accent/10">
                <s.Icon size={24} className="text-accent" />
              </div>
              <div class="mb-2 font-mono text-xs font-semibold text-accent">STEP {s.step}</div>
              <h3 class="text-[15px] font-semibold text-text-primary mb-2">{s.title}</h3>
              <p class="text-sm leading-relaxed text-text-tertiary">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <div class="px-4 sm:px-6 mx-auto max-w-4xl"><div class="border-t border-border"></div></div>

      {/* Use Cases */}
      <section class="px-4 sm:px-6 py-16 sm:py-20 md:py-24 mx-auto max-w-5xl">
        <div class="mb-14 text-center">
          <div class="text-[11px] font-semibold text-accent mb-3 tracking-widest uppercase">Use cases</div>
          <h2 class="text-2xl font-bold tracking-tight text-text-primary">You chat. nexu executes.</h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
          {useCases.map((c) => (
            <div class="flex gap-5 items-start p-5 rounded-xl border bg-surface-1 border-border">
              <div class="flex justify-center items-center w-10 h-10 rounded-xl shrink-0 bg-accent/10">
                <c.Icon size={18} className="text-accent" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex gap-2 items-center mb-1.5">
                  <span class="text-[10px] font-medium text-accent bg-accent/10 px-1.5 py-0.5 rounded-full">{c.tag}</span>
                </div>
                <div class="text-[14px] font-semibold text-text-primary mb-1">{c.prompt}</div>
                <div class="text-[13px] text-text-muted mb-2">{c.result}</div>
                <div class="inline-flex gap-1 items-center text-[11px] text-accent bg-accent/10 px-2 py-0.5 rounded-full font-medium">
                  <Clock size={10} /> {c.time}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <div class="px-4 sm:px-6 mx-auto max-w-4xl"><div class="border-t border-border"></div></div>

      {/* Numbers */}
      <section class="px-4 sm:px-6 py-16 sm:py-20 md:py-24 mx-auto max-w-4xl">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {stats.map((n) => (
            <div>
              <div class="font-mono text-3xl font-bold tracking-tight text-accent">{n.num}</div>
              <div class="mt-1 text-sm font-medium text-text-primary">{n.label}</div>
              <div class="text-[11px] text-text-muted mt-0.5">{n.sub}</div>
            </div>
          ))}
        </div>
      </section>

      <div class="px-4 sm:px-6 mx-auto max-w-4xl"><div class="border-t border-border"></div></div>

      {/* FAQ (React island — interactive accordion) */}
      <FAQSection client:visible />

      {/* Final CTA */}
      <section class="overflow-hidden relative">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(var(--color-accent-rgb,99,102,241),0.05)_0%,transparent_60%)]"></div>
        <div class="relative px-4 sm:px-6 py-16 sm:py-20 md:py-24 mx-auto max-w-3xl text-center">
          <h2 class="mb-4 text-3xl font-bold tracking-tight text-text-primary">Give your lobster a real workplace.</h2>
          <p class="mb-8 text-base text-text-tertiary">Start free, connect your channels, and turn daily chat into reusable team leverage.</p>
          <div class="flex gap-3 justify-center">
            <a href="/auth" class="flex gap-2 items-center px-6 sm:px-8 py-3 text-sm font-semibold rounded-lg transition-all bg-accent hover:bg-accent-hover text-accent-fg hover:shadow-lg hover:shadow-accent/20">
              Get started free <ArrowRight size={14} />
            </a>
          </div>
        </div>
      </section>

      {/* Footer */}
      <footer class="border-t border-border">
        <div class="flex flex-col gap-4 md:flex-row md:justify-between md:items-center px-4 sm:px-6 py-8 mx-auto max-w-5xl">
          <div class="flex items-center gap-2.5">
            <BrandMark className="w-5 h-5" />
            <span class="text-xs text-text-muted">&copy; 2026 Powerformer, Inc.</span>
          </div>
          <div class="flex flex-wrap gap-x-5 gap-y-2 text-xs text-text-muted">
            <a href="#" class="transition-colors hover:text-text-secondary">X / Twitter</a>
            <a href="#" class="transition-colors hover:text-text-secondary">Docs</a>
            <a href="/privacy" class="transition-colors hover:text-text-secondary">Privacy Policy</a>
            <a href="/terms" class="transition-colors hover:text-text-secondary">Terms of Service</a>
          </div>
        </div>
      </footer>

    </div>
    <script>
      import * as amplitude from "@amplitude/unified";

      const apiKey = import.meta.env.PUBLIC_AMPLITUDE_API_KEY;
      if (apiKey) {
        amplitude.initAll(apiKey, {
          analytics: { autocapture: true },
          sessionReplay: { sampleRate: 1 },
        });

        amplitude.track("landing_view");

        document.querySelectorAll<HTMLAnchorElement>('a[href="/auth"]').forEach((el) => {
          el.addEventListener("click", () => {
            amplitude.track("landing_cta_click");
          });
        });
      }
    </script>
  </body>
</html>
