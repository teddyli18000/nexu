{
  "name": "nexu",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --dir ./scripts/dev exec tsx ./src/index.ts",
    "dev:controller": "pnpm --filter @nexu/controller dev",
    "dev:desktop": "pnpm --filter @nexu/desktop dev",
    "build": "pnpm -r build",
    "check:esm-imports": "node scripts/check-esm-specifiers.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check . && pnpm -r typecheck",
    "lint:fix": "biome check --write --unsafe . && pnpm -r typecheck",
    "format": "biome check --write .",
    "test": "vitest run",
    "generate-types": "pnpm --filter @nexu/controller generate-openapi && pnpm --filter @nexu/web generate-sdk",
    "openclaw-runtime:install": "npm --prefix ./openclaw-runtime run install:cached",
    "openclaw-runtime:refresh-lock": "npm --prefix ./openclaw-runtime run refresh-lock",
    "openclaw-runtime:reinstall": "npm --prefix ./openclaw-runtime run clean && npm --prefix ./openclaw-runtime run install:pruned",
    "postinstall": "npm --prefix ./openclaw-runtime run install:pruned && npm --prefix ./apps/controller/static/runtime-plugins/openclaw-weixin install --production --ignore-scripts && node ./scripts/clean-runtime-plugin-installs.mjs",
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "start": "node ./scripts/desktop-dev.mjs start",
    "stop": "node ./scripts/desktop-dev.mjs stop",
    "restart": "node ./scripts/desktop-dev.mjs restart",
    "reset-state": "node ./scripts/desktop-dev.mjs reset-state",
    "status": "node ./scripts/desktop-dev.mjs status",
    "logs": "node ./scripts/desktop-dev.mjs logs",
    "check:dev": "node ./scripts/desktop-check-dev.mjs",
    "check:dist": "node ./scripts/desktop-check-dist.mjs",
    "probe:slack": "node scripts/probe/slack-reply-probe.mjs",
    "dist:mac": "pnpm --filter @nexu/desktop dist:mac",
    "dist:mac:arm64": "pnpm --filter @nexu/desktop dist:mac:arm64",
    "dist:mac:x64": "pnpm --filter @nexu/desktop dist:mac:x64",
    "dist:mac:unsigned": "pnpm --filter @nexu/desktop dist:mac:unsigned",
    "dist:mac:unsigned:arm64": "pnpm --filter @nexu/desktop dist:mac:unsigned:arm64",
    "dist:mac:unsigned:x64": "pnpm --filter @nexu/desktop dist:mac:unsigned:x64"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    }
  }
}
