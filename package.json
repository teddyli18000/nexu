{
  "name": "nexu",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=development concurrently --kill-others --names controller,web --prefix-colors blue,green \"pnpm --filter @nexu/controller dev\" \"pnpm --filter @nexu/web dev\"",
    "dev:legacy": "NODE_OPTIONS=--conditions=development concurrently --kill-others --names api,web --prefix-colors blue,green \"pnpm --filter @nexu/api dev\" \"pnpm --filter @nexu/web dev\"",
    "dev:legacy:gateway": "concurrently --kill-others --names gateway --prefix-colors cyan \"pnpm --filter @nexu/gateway dev\"",
    "dev:controller": "pnpm --filter @nexu/controller dev",
    "dev:desktop": "pnpm --filter @nexu/desktop dev",
    "build": "pnpm -r build",
    "check:esm-imports": "node scripts/check-esm-specifiers.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check . && pnpm -r typecheck",
    "lint:fix": "biome check --write --unsafe . && pnpm -r typecheck",
    "format": "biome check --write .",
    "test": "vitest run",
    "generate-types": "pnpm --filter @nexu/controller generate-openapi && pnpm --filter @nexu/web generate-sdk",
    "openclaw-runtime:install": "npm --prefix ./openclaw-runtime run install:pruned",
    "openclaw-runtime:refresh-lock": "npm --prefix ./openclaw-runtime run refresh-lock",
    "openclaw-runtime:reinstall": "npm --prefix ./openclaw-runtime run clean && npm --prefix ./openclaw-runtime run install:pruned",
    "preinstall": "npm --prefix ./openclaw-runtime run clean",
    "postinstall": "npm --prefix ./openclaw-runtime run install:pruned",
    "prepare": "cp scripts/pre-commit .git/hooks/pre-commit 2>/dev/null; chmod +x .git/hooks/pre-commit 2>/dev/null; true",
    "seed": "pnpm --filter @nexu/api db:seed",
    "db:generate": "pnpm --filter @nexu/api db:generate",
    "db:migrate": "pnpm --filter @nexu/api db:migrate",
    "db:check-sync": "pnpm --filter @nexu/api db:check-sync",
    "db:check-sync:missing": "pnpm --filter @nexu/api db:check-sync:missing",
    "db:check-sync:mismatch": "pnpm --filter @nexu/api db:check-sync:mismatch",
    "db:check-dangerous": "pnpm --filter @nexu/api db:check-dangerous",
    "db:check-dangerous-sql": "pnpm --filter @nexu/api db:check-dangerous-sql",
    "db:push": "pnpm --filter @nexu/api db:push",
    "desktop:start": "./apps/desktop/dev.sh start",
    "desktop:stop": "./apps/desktop/dev.sh stop",
    "desktop:restart": "./apps/desktop/dev.sh restart",
    "desktop:status": "./apps/desktop/dev.sh status",
    "desktop:logs": "./apps/desktop/dev.sh logs",
    "desktop:check:dev": "./scripts/desktop-check-dev.sh",
    "desktop:check:dist": "./scripts/desktop-check-dist.sh",
    "probe:slack": "node scripts/probe/slack-reply-probe.mjs",
    "desktop:dist:mac": "pnpm --filter @nexu/desktop dist:mac",
    "desktop:dist:mac:unsigned": "pnpm --filter @nexu/desktop dist:mac:unsigned"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "electron", "esbuild"],
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    }
  }
}
